{
  "buildCommand": "npx expo export -p web",
  "installCommand": "npm install",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@5.1.8",
      "includeFiles": "dist/server/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!_expo|assets|favicon.ico).*)",
      "destination": "/api/index"
    }
  ]
}
